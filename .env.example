# Copy to .env and fill in. The .env file is git-ignored.

# Required only for the AI-written report (stage 9). Every other stage works
# without it. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used to write the report. Defaults to claude-opus-4-8 (most capable) if
# unset. Opus 4.8 gives the strongest written analysis; switch to
# claude-sonnet-4-6 for a faster/cheaper report.
REPORT_MODEL=claude-opus-4-8
